# CollectiveAccess API
# Full URL including trailing slash — or use --domain flag on the CLI
CA_BASE_URL=https://ca.israelalbum.org.il/service.php/json/

CA_USER=administrator
CA_PASSWORD=your_password_here

# Locale for representation labels (default: he_IL)
CA_LOCALE=he_IL

# representation→object relationship type ID (135 on YNL and eretzhefetz)
REL_TYPE_ID=135

# Museum switching — required when the API user is not in the target museum
# CA_USER_ID: numeric ID of the API user (check CA admin: Administration > User accounts)
# CA_MUSEUM_ID: numeric museum ID to switch to (23 = YBZ on israelalbum)
CA_USER_ID=
CA_MUSEUM_ID=
